# Panda API Configuration
# Privacy-first RAG chatbot with local LLM support

# =============================================================================
# LLM PROVIDER CONFIGURATION
# Priority: 1) Ollama (local) > 2) OpenAI (cloud) > 3) Mock (fallback)
# =============================================================================

# OpenAI API Key (optional - only if you want to use OpenAI)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Configuration
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Ollama Configuration (for local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:3b  # or phi4 (3B parameters, fits in 8GB RAM)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_ENABLED=true

# Local Embedding Fallback (when no API keys available)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2  # 80MB, 384 dimensions, fits in 8GB RAM

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================

SESSION_TIMEOUT_MINUTES=30
MAX_FILE_SIZE_MB=50
MAX_TOTAL_SIZE_MB=100

# =============================================================================
# CHUNKING CONFIGURATION
# =============================================================================

CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=100
MAX_CHUNKS_PER_QUERY=5

# =============================================================================
# CHAT MEMORY CONFIGURATION
# =============================================================================

MAX_CHAT_HISTORY_TURNS=7  # Last N conversation turns to include in context
CONVERSATION_SUMMARY_THRESHOLD=10  # Summarize after N turns
MAX_SUMMARY_TOKENS=500

# =============================================================================
# RAG CONFIGURATION
# =============================================================================

RELEVANCE_THRESHOLD=0.7  # Minimum similarity score for responses
ENABLE_HYBRID_SEARCH=true  # Combine FAISS + BM25
BM25_WEIGHT=0.3  # Weight for BM25 in hybrid search (0-1)

# =============================================================================
# PERFORMANCE CONFIGURATION (for 8GB RAM)
# =============================================================================

DOCUMENT_BATCH_SIZE=3  # Process PDF pages in chunks
MAX_CONCURRENT_REQUESTS=3  # Request queue limit

# =============================================================================
# SESSION PERSISTENCE
# =============================================================================

ENABLE_SESSION_PERSISTENCE=true
BACKUP_DIR=backups

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# =============================================================================
# DEBUG CONFIGURATION
# =============================================================================

DEBUG=false
